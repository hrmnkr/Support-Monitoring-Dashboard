<script>

    var labels = [];
    var counts = [];

    @foreach (var s in ViewBag.SourceData)
    {
        <text>
            labels.push("@s.Source");
            counts.push(@s.Count);
        </text>
    }

    new Chart(document.getElementById("sourceChart"), {
    type: 'pie',
    data: {
    labels: labels,
    datasets: [{
    data: counts
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false
    }
    });

    var reporterLabels = [];
    var reporterCounts = [];

    @foreach (var r in ViewBag.ReporterData)
    {
        <text>
            reporterLabels.push("@r.Reporter");
            reporterCounts.push(@r.Count);
        </text>
    }

    new Chart(document.getElementById("reporterChart"), {
    type: 'bar',
    data: {
    labels: reporterLabels,
    datasets: [{
    label: 'Issues by Reporter',
    data: reporterCounts
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false
    }
    });

    document.getElementById("searchBox").addEventListener("keyup", function() {

    var value = this.value.toLowerCase();
    var rows = document.querySelectorAll("tbody tr");

    rows.forEach(function(row) {

    row.style.display =
    row.innerText.toLowerCase().includes(value) ? "" : "none";

    });

    });

    var trendLabels = [];
    var trendCounts = [];

    @foreach (var t in ViewBag.TrendData)
    {
        <text>
            trendLabels.push("@t.Date");
            trendCounts.push(@t.Count);
        </text>
    }

    new Chart(document.getElementById("trendChart"), {
    type: 'line',
    data: {
    labels: trendLabels,
    datasets: [{
    label: 'Issues per Day',
    data: trendCounts,
    fill: false,
    tension: 0.1
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false
    }
    });

</script>

<script>
    setTimeout(function () {
    location.reload();
    }, 30000); // refresh every 30 seconds
</script>